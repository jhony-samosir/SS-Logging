{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "gridPos": { "h": 7, "w": 16, "x": 0, "y": 0 },
      "id": 1,
      "title": "📈 Log Volume by Service Over Time",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "editorMode": "code",
          "expr": "sum by(container_name) (count_over_time({job=\"fluentbit\"}[$__interval]))",
          "legendFormat": "{{container_name}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 0 },
      "id": 2,
      "title": "🥧 Service Log Distribution",
      "type": "piechart",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "editorMode": "code",
          "expr": "sum by(container_name) (count_over_time({job=\"fluentbit\"}[$__range]))",
          "legendFormat": "{{container_name}}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent", "value"] },
        "tooltip": { "mode": "single" },
        "pieType": "donut"
      }
    },
    {
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 7 },
      "id": 3,
      "title": "🔴 Error Logs",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"fluentbit\"} |~ \"(?i)(\\\"level\\\":\\\"error\\\"|\\\"@l\\\":\\\"Error\\\"|ERROR|CRIT|FATAL)\"[$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "dark-red" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-green", "value": null },
              { "color": "dark-red", "value": 1 }
            ]
          },
          "mappings": [{ "type": "special", "options": { "match": "null", "result": { "text": "0" } } }]
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "value" }
    },
    {
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 7 },
      "id": 4,
      "title": "🟡 Warning Logs",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"fluentbit\"} |~ \"(?i)(\\\"level\\\":\\\"warn\\\"|\\\"@l\\\":\\\"Warning\\\"|WARN)\"[$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "dark-orange" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-green", "value": null },
              { "color": "dark-orange", "value": 1 }
            ]
          },
          "mappings": [{ "type": "special", "options": { "match": "null", "result": { "text": "0" } } }]
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "value" }
    },
    {
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 7 },
      "id": 5,
      "title": "📊 Total Logs",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"fluentbit\"}[$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "dark-blue" },
          "mappings": [{ "type": "special", "options": { "match": "null", "result": { "text": "0" } } }]
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "value" }
    },
    {
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 11 },
      "id": 6,
      "title": "📋 Live Log Stream",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "editorMode": "code",
          "expr": "{job=\"fluentbit\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "prettifyLogMessage": false,
        "dedupStrategy": "none"
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["samstore", "logging", "loki"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "timezone": "browser",
  "title": "SamStore Services Logs Dashboard",
  "uid": "samstore-logs",
  "version": 2
